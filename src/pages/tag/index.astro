---
import Layout from "../../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import Tag from "../../components/ui/Tag.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { experiences } from "../../data/experience";

const posts: CollectionEntry<"blog">[] = await getCollection("blog");
const projects: CollectionEntry<"projects">[] = await getCollection("projects");

const tagCounts = [
    ...posts,
    ...projects,
    ...experiences.map((e) => ({ data: { tags: e.technologies } })),
].reduce(
    (acc: Record<string, number>, item: { data: { tags?: string | string[] } }) => {
        let tags: string[] = [];
        try {
            tags =
                typeof item.data.tags === "string"
                    ? JSON.parse(item.data.tags)
                    : item.data.tags || [];
        } catch (e) {}
        tags.forEach((tag) => {
            const normalized = tag.toLowerCase();
            acc[normalized] = (acc[normalized] || 0) + 1;
        });
        return acc;
    },
    {} as Record<string, number>,
);

const uniqueTags = (Object.entries(tagCounts) as [string, number][]).sort(
    (a, b) => b[1] - a[1],
);

const metadata = {
    title: "All Tags",
    description: "Explore posts by their topics and technologies.",
};
---

<Layout title={metadata.title} description={metadata.description} mainClass="py-16 max-w-full">
    <Breadcrumb crumbs={[]} current="Tags" />
    <header class="mb-16">
      <h1 class="font-display text-5xl sm:text-6xl font-bold text-primary leading-[0.95] tracking-tight" data-animate data-delay="1">All Tags</h1>
    </header>
        <div class="flex flex-wrap gap-3">
            {
                uniqueTags.map(([tag, count], i) => (
                    <a href={`/tag/${tag.toLowerCase()}`} class="group" data-animate data-delay={String((i % 4) + 1)}>
                        <div class="flex items-center gap-2 px-5 py-3 rounded-lg bg-surface border border-border/60 hover:border-accent/40 hover:bg-accent/5 transition-all duration-250">
                            <span class="font-sans text-base font-bold text-primary group-hover:text-accent transition-colors tracking-wide">
                                #{tag}
                            </span>
                            <span class="font-sans text-xs text-secondary/60">
                                ({count})
                            </span>
                        </div>
                    </a>
                ))
            }
        </div>
</Layout>
