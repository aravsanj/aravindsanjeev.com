---
import Layout from "../../layouts/Layout.astro";
import PostsByTag from "../../components/PostsByTag.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import Project from "../../components/Project.astro";
import TagComponent from "../../components/ui/Tag.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { experiences } from "../../data/experience";

type BlogEntry = CollectionEntry<"blog">;
type ProjectEntry = CollectionEntry<"projects">;

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((post: BlogEntry) => !post.data.isDraft);
  const projects = await getCollection("projects");

  const allContent = [
    ...posts,
    ...projects,
    ...experiences.map((e) => ({ data: { tags: e.technologies } })),
  ];

  const uniqueTags = [
    ...new Set(
      allContent.flatMap(
        (item: BlogEntry | ProjectEntry | { data: { tags: string[] } }) => {
          let tags: string[] = [];
          try {
            tags =
              typeof item.data.tags === "string"
                ? JSON.parse(item.data.tags)
                : item.data.tags || [];
          } catch (e) {}
          return tags.map((t: string) => t.toLowerCase());
        },
      ),
    ),
  ];

  return uniqueTags.map((tag) => {
    const filteredPosts = posts.filter((post: BlogEntry) => {
      let tags: string[] = [];
      try {
        tags =
          typeof post.data.tags === "string"
            ? JSON.parse(post.data.tags)
            : post.data.tags || [];
      } catch (e) {}
      return tags.some((t: string) => t.toLowerCase() === tag);
    });

    const filteredProjects = projects
      .filter((project: ProjectEntry) => {
        let tags: string[] = [];
        try {
          tags =
            typeof project.data.tags === "string"
              ? JSON.parse(project.data.tags)
              : project.data.tags || [];
        } catch (e) {}
        return tags.some((t: string) => t.toLowerCase() === tag);
      })
      .sort((a: ProjectEntry, b: ProjectEntry) => {
        const priorityA = a.data.priority ?? 0;
        const priorityB = b.data.priority ?? 0;
        if (priorityA !== priorityB) return priorityB - priorityA;
        const dateA = a.data.publishedAt
          ? new Date(a.data.publishedAt).valueOf()
          : 0;
        const dateB = b.data.publishedAt
          ? new Date(b.data.publishedAt).valueOf()
          : 0;
        return dateB - dateA;
      });

    const filteredExperiences = experiences.filter((exp) => {
      return exp.technologies.some((t: string) => t.toLowerCase() === tag);
    });

    return {
      params: { tag },
      props: {
        posts: filteredPosts,
        projects: filteredProjects,
        experiences: filteredExperiences,
      },
    };
  });
}

const { tag } = Astro.params;
const { posts, projects, experiences: matchedExperiences } = Astro.props;
---

<Layout title={`Content tagged with ${tag}`} mainClass="py-24 max-w-full">
  <Breadcrumb crumbs={[{ label: "Tags", href: "/tag" }]} current={`#${tag}`} />
  <div class="text-center mb-16">
    <div class="font-mono text-xs uppercase tracking-[0.2em] text-secondary/60 mb-3" data-animate>&gt; filter_by_tag</div>
    <h1 class="font-display text-5xl sm:text-6xl font-bold uppercase tracking-tight text-primary" data-animate data-delay="1">
      <span class="text-accent/50">#</span>{tag}
    </h1>
  </div>

  <div class="space-y-24">
    {
      posts && posts.length > 0 && (
        <section>
          <h2 class="font-display text-2xl font-bold uppercase tracking-wide text-primary mb-8 border-b border-accent/20 pb-4" data-animate>
            <span class="text-accent/60 font-mono text-base mr-2">//</span>Articles
          </h2>
          <PostsByTag posts={posts} />
        </section>
      )
    }

    {
      projects && projects.length > 0 && (
        <section>
          <h2 class="font-display text-2xl font-bold uppercase tracking-wide text-primary mb-8 border-b border-accent/20 pb-4" data-animate>
            <span class="text-accent/60 font-mono text-base mr-2">//</span>Projects
          </h2>

          <div class="archive-header">
            <span class="col-year">Year</span>
            <span class="col-project">Project</span>
            <span class="col-stack">Built with</span>
            <span class="col-link">Link</span>
          </div>

          <div class="archive-list">
            {projects.map((project: ProjectEntry, i: number) => {
              const year = project.data.publishedAt
                ? new Date(project.data.publishedAt).getFullYear()
                : "—";
              const hasUrl = !!project.data.url;
              const domain = project.data.url
                ? new URL(project.data.url).hostname.replace(/^www\./, "")
                : null;

              return (
                <div class="archive-row" style={`animation-delay: ${(i * 60) + 200}ms`}>
                  <span class="col-year">{year}</span>

                  <span class="col-project">
                    {hasUrl ? (
                      <a href={project.data.url} target="_blank" rel="noopener noreferrer" class="project-name-link">
                        {project.data.title}
                      </a>
                    ) : (
                      <span class="project-name">{project.data.title}</span>
                    )}
                    <span class="project-desc">{project.data.description}</span>
                  </span>

                  <span class="col-stack">
                    {project.data.tags && project.data.tags.length > 0 ? (
                      <span class="tag-group">
                        {project.data.tags.map((t: string) => (
                          <a href={`/tag/${t.toLowerCase().replace(/\s+/g, '-')}`} class="tech-tag">{t}</a>
                        ))}
                      </span>
                    ) : (
                      <span class="no-data">—</span>
                    )}
                  </span>

                  <span class="col-link">
                    {hasUrl ? (
                      <a href={project.data.url} target="_blank" rel="noopener noreferrer" class="ext-link" aria-label={`Visit ${project.data.title}`}>
                        <span class="link-domain">{domain}</span>
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </a>
                    ) : (
                      <span class="no-data">—</span>
                    )}
                  </span>
                </div>
              );
            })}
          </div>
        </section>
      )
    }

    {
      matchedExperiences && matchedExperiences.length > 0 && (
        <section>
          <h2 class="font-display text-2xl font-bold uppercase tracking-wide text-primary mb-8 border-b border-accent/20 pb-4" data-animate>
            <span class="text-accent/60 font-mono text-base mr-2">//</span>Experience
          </h2>
          <div class="grid md:grid-cols-2 gap-8">
            {matchedExperiences.map((item, i: number) => (
              <div class="hud-frame hud-corners card-lift card-sweep group relative flex flex-col gap-6 p-6 bg-surface/60 border border-border hover:border-accent/30 transition-all duration-300" data-animate data-delay={String((i % 2) + 1)}>
                <div class="flex flex-col flex-1">
                  <header class="mb-4">
                    <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-accent bg-accent/8 border border-accent/25 px-2.5 py-1 inline-block mb-3">
                      {item.duration}
                    </span>
                    <h3 class="font-display text-xl font-bold uppercase tracking-wide text-primary group-hover:text-accent transition-colors">
                      <a
                        href={item.companyUrl}
                        target="_blank"
                        rel="noreferrer noopener"
                        class="after:absolute after:inset-0"
                      >
                        {`${item.title} · ${item.company}`}
                      </a>
                    </h3>
                  </header>

                  <p class="text-secondary text-base leading-relaxed mb-6">
                    {item.description}
                  </p>

                  <ul class="mt-auto flex flex-wrap gap-2 relative z-10">
                    {item.technologies.map((tech: string) => (
                      <li>
                        <TagComponent
                          title={tech}
                          href={`/tag/${tech.toLowerCase()}`}
                        />
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ))}
          </div>
        </section>
      )
    }
  </div>
</Layout>

<style>
  .archive-header,
  .archive-row {
    display: grid;
    grid-template-columns: 4rem 1fr 1fr 12rem;
    gap: 0 2rem;
    align-items: start;
    padding: 0 0.25rem;
  }

  @media (max-width: 900px) {
    .archive-header,
    .archive-row {
      grid-template-columns: 3.5rem 1fr 1fr;
    }
    .col-link { display: none; }
  }

  @media (max-width: 600px) {
    .archive-header,
    .archive-row {
      grid-template-columns: 3rem 1fr;
    }
    .col-stack,
    .col-link { display: none; }
  }

  .archive-header {
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(182, 255, 26, 0.25);
    margin-bottom: 0;
    font-family: "Share Tech Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(182, 255, 26, 0.45);
  }

  .archive-list { position: relative; }

  @keyframes rowIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .archive-row {
    padding: 1.25rem 0.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: background 0.2s ease;
    position: relative;
    cursor: default;
    opacity: 0;
    animation: rowIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .archive-row::before {
    content: "";
    position: absolute;
    left: -1.5rem;
    right: -1.5rem;
    top: 0;
    bottom: 0;
    background: rgba(182, 255, 26, 0.03);
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .archive-row:hover::before { opacity: 1; }

  .archive-row:hover .col-year { color: rgba(182, 255, 26, 0.8); }

  .archive-row:hover .project-name,
  .archive-row:hover .project-name-link { color: #b6ff1a; }

  .col-year {
    font-family: "Share Tech Mono", monospace;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.05em;
    padding-top: 0.2rem;
    transition: color 0.2s ease;
  }

  .col-project {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .project-name {
    font-family: "Oxanium", sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    transition: color 0.2s ease;
    line-height: 1.3;
  }

  .project-name-link {
    font-family: "Oxanium", sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    transition: color 0.2s ease;
    line-height: 1.3;
  }

  .project-name-link:hover { color: #b6ff1a; }

  .project-desc {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.35);
    line-height: 1.5;
    font-family: "Inter", sans-serif;
    max-width: 36ch;
  }

  .col-stack { padding-top: 0.15rem; }

  .tag-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tech-tag {
    font-family: "Share Tech Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    padding: 0.2rem 0.5rem;
    border: 1px solid rgba(182, 255, 26, 0.2);
    color: rgba(182, 255, 26, 0.6);
    background: rgba(182, 255, 26, 0.04);
    border-radius: 2px;
    white-space: nowrap;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .tech-tag:hover {
    border-color: rgba(182, 255, 26, 0.6);
    color: rgba(182, 255, 26, 1);
    background: rgba(182, 255, 26, 0.12);
  }

  .archive-row:hover .tech-tag {
    border-color: rgba(182, 255, 26, 0.35);
    color: rgba(182, 255, 26, 0.8);
    background: rgba(182, 255, 26, 0.07);
  }

  .col-link { padding-top: 0.2rem; }

  .ext-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: "Share Tech Mono", monospace;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .ext-link:hover { color: #b6ff1a; }

  .link-domain {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .no-data {
    font-family: "Share Tech Mono", monospace;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.15);
  }
</style>
