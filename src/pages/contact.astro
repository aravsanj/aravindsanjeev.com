---
import Layout from "../layouts/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";

const metadata = {
    title: "Hire Me",
    description: "Get in touch for projects, collaborations, or just to say hi.",
};
---

<Layout title={metadata.title} description={metadata.description} mainClass="py-24">
    <Breadcrumb crumbs={[]} current="Hire Me" />
    <div class="section-label" data-animate>
      <span class="section-label-num">//</span>
      <span class="section-label-text">establish_uplink</span>
      <div class="section-label-rule"></div>
    </div>
    <h1 class="font-display text-5xl sm:text-6xl font-bold uppercase tracking-tight text-primary mb-8" data-animate data-delay="1">Hire Me</h1>

    <div class="grid lg:grid-cols-[1fr_360px] gap-8 items-start">

        <!-- Left: contact form -->
        <div>
            <div class="mb-10" data-animate data-delay="2">
                <p class="font-mono text-base text-secondary mb-4 leading-relaxed">
                    I'm always open to discussing new projects, creative ideas or opportunities to be part of your visions.
                </p>
                <div class="hud-frame hud-corners flex items-center gap-3 p-4 bg-surface/60 border border-border">
                    <span class="font-mono text-accent">&gt;</span>
                    <a href="mailto:hi@aravindsanjeev.com" class="font-mono text-base text-primary hover:text-accent transition-colors break-all">
                        hi@aravindsanjeev.com
                    </a>
                </div>
            </div>

            <div class="flex items-center gap-4 mb-10">
                <div class="h-px flex-1 bg-gradient-to-r from-transparent to-accent/25"></div>
                <span class="font-mono text-accent/50 text-xs uppercase tracking-[0.2em]">// or</span>
                <div class="h-px flex-1 bg-gradient-to-l from-transparent to-accent/25"></div>
            </div>

            <div class="hud-frame hud-corners bg-surface/60 p-8 border border-border" data-animate data-delay="3">
                <div class="font-mono text-[11px] uppercase tracking-[0.18em] text-accent/70 mb-6">&gt; new_message.init()</div>
                <form id="contact-form" action="https://script.google.com/macros/s/AKfycbywKg0hophDZMU28QdM0Px5PZlcboebKY_NrNO7YkQ_BV-3h4_qgJvhjkWDynzyGE7WSg/exec" method="POST" class="space-y-6">
                    <div>
                        <label for="name" class="block font-mono text-xs uppercase tracking-[0.12em] text-secondary mb-2">// name</label>
                        <input
                            type="text"
                            id="name"
                            name="name"
                            required
                            placeholder="john_doe"
                            class="w-full px-4 py-3 bg-background border border-border text-primary font-mono focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all placeholder:text-secondary/30"
                        />
                    </div>
                    <div>
                        <label for="email" class="block font-mono text-xs uppercase tracking-[0.12em] text-secondary mb-2">// email</label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            placeholder="john@example.com"
                            class="w-full px-4 py-3 bg-background border border-border text-primary font-mono focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all placeholder:text-secondary/30"
                        />
                    </div>
                    <div>
                        <label for="message" class="block font-mono text-xs uppercase tracking-[0.12em] text-secondary mb-2">// message</label>
                        <textarea
                            id="message"
                            name="message"
                            rows="5"
                            required
                            placeholder="tell me about your project..."
                            class="w-full px-4 py-3 bg-background border border-border text-primary font-mono focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all placeholder:text-secondary/30 resize-none"
                        ></textarea>
                    </div>
                    <button
                        type="submit"
                        class="w-full py-4 bg-accent text-background font-mono text-sm uppercase tracking-[0.14em] hover:bg-accent-bright transition-all transform active:scale-[0.98] acid-glow"
                    >
                        [ transmit_message ]
                    </button>
                </form>
                <div id="form-status" class="mt-4 text-center hidden">
                    <p class="text-sm font-mono"></p>
                </div>
            </div>
        </div>

        <!-- Right: strategy call CTA -->
        <div class="lg:sticky lg:top-28" data-animate data-delay="2">
            <div class="hud-frame hud-corners hud-frame--hot hud-corners--hot bg-surface/60 border border-border p-8">
                <div class="w-12 h-12 bg-hot/10 border border-hot/30 flex items-center justify-center mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-hot" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                </div>

                <h2 class="font-display text-xl font-bold uppercase tracking-wide text-primary mb-2">Book a Strategy Call</h2>
                <p class="font-body text-secondary text-sm leading-relaxed mb-6">
                    Got a project in mind? Let's talk through your goals, challenges, and how I can help &mdash; no strings attached.
                </p>

                <ul class="space-y-3 mb-8">
                    <li class="flex items-center gap-3 font-mono text-xs text-secondary">
                        <span class="text-accent">&gt;</span>15-minute focused session
                    </li>
                    <li class="flex items-center gap-3 font-mono text-xs text-secondary">
                        <span class="text-accent">&gt;</span>talk through your project or idea
                    </li>
                    <li class="flex items-center gap-3 font-mono text-xs text-secondary">
                        <span class="text-accent">&gt;</span>get honest technical advice
                    </li>
                    <li class="flex items-center gap-3 font-mono text-xs text-secondary">
                        <span class="text-accent">&gt;</span>free, no obligation
                    </li>
                </ul>

                <a
                    href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ3XMK9NOox_TPLSyObRx_nRYu49-PV1f2bGqMqrCOp-vYJdiNP2MfcdKTSxxtfrR3IjO6PeHW9z"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-center gap-2 w-full py-3.5 border border-hot/40 text-hot font-mono text-xs uppercase tracking-[0.12em] hover:bg-hot hover:text-background transition-all"
                >
                    [ pick_a_time ]
                </a>
            </div>
        </div>

    </div>
</Layout>

<script is:inline src="https://www.google.com/recaptcha/api.js?render=6Lesx0IsAAAAAEcCZpemdGpSQFiIr-w8jx_aKa6c"></script>

<script is:inline>
    const form = document.getElementById('contact-form');
    const status = document.getElementById('form-status');
    const statusText = status.querySelector('p');
    const SITE_KEY = '6Lesx0IsAAAAAEcCZpemdGpSQFiIr-w8jx_aKa6c';

    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const button = form.querySelector('button');
            const originalText = button.textContent;

            button.disabled = true;
            button.textContent = 'Sending...';

            try {
                // Execute reCAPTCHA
                const token = await new Promise((resolve, reject) => {
                    grecaptcha.ready(() => {
                        grecaptcha.execute(SITE_KEY, {action: 'submit'})
                            .then(resolve)
                            .catch(reject);
                    });
                });

                const formData = new FormData(form);
                formData.append('g-recaptcha-response', token);

                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData,
                });

                const data = await response.json();

                if (response.ok && data.result === 'success') {
                    status.classList.remove('hidden');
                    statusText.textContent = "Thanks! I'll get back to you soon. Redirecting...";
                    statusText.className = "text-green-500 font-medium";
                    button.textContent = 'Sent!';
                    form.reset();
                    
                    // Redirect to home page after 2 seconds
                     setTimeout(() => {
                         window.location.href = '/';
                     }, 2000);
                } else {
                    throw new Error(data.error || 'Form submission failed');
                }
            } catch (error) {
                console.error('Submission error:', error);
                status.classList.remove('hidden');
                statusText.textContent = "There was error while submitting.";
                statusText.className = "text-red-500 font-medium";
                button.disabled = false;
                button.textContent = originalText;
            }
        });
    }
</script>
