---
import Layout from "../../layouts/Layout.astro";
import { videos } from "../../data/videos";
import Breadcrumb from "../../components/Breadcrumb.astro";

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
  });
}

const metadata = {
  title: "Videos | Aravind Sanjeev",
  description:
    "Watch my videos on software engineering, AI, React, TypeScript, and more.",
};
---

<Layout
  title={metadata.title}
  description={metadata.description}
  mainClass="py-16 max-w-full"
>
  <Breadcrumb crumbs={[]} current="Videos" />

  <!-- Page header -->
  <header class="mb-20">
    <h1
      class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold text-primary leading-[0.95] tracking-tight mb-6"
      data-animate
      data-delay="1"
    >
      Videos
    </h1>
    <p class="text-secondary text-lg max-w-xl leading-relaxed" data-animate data-delay="2">
      Screencasts, talks, and walkthroughs on engineering, AI, and the tools I use.
      Subscribe on
      <a
        href="https://youtube.com/@aravsanj"
        target="_blank"
        rel="noreferrer"
        class="text-accent hover:text-fuchsia-300 transition-colors underline underline-offset-2"
      >
        YouTube
      </a>.
    </p>
  </header>

  <!-- Video grid -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {
      videos.map((video, i) => (
        <a
          href={`https://www.youtube.com/watch?v=${video.id}`}
          target="_blank"
          rel="noreferrer"
          class="video-card group relative flex flex-col rounded-2xl bg-surface border border-white/5 hover:border-accent/25 overflow-hidden card-lift transition-all duration-400"
          data-animate
          data-delay={String((i % 3) + 1)}
          aria-label={`Watch: ${video.title}`}
        >
          <!-- Thumbnail -->
          <div class="relative aspect-video overflow-hidden bg-surface-2">
            <img
              src={`https://img.youtube.com/vi/${video.id}/maxresdefault.jpg`}
              alt={video.title}
              loading={i < 3 ? "eager" : "lazy"}
              class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-700 ease-out"
              onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','hqdefault')"
            />

            <!-- Dark overlay on hover -->
            <div class="video-thumb-overlay absolute inset-0" />

            <!-- Play button -->
            <div class="video-play-btn absolute inset-0 flex items-center justify-center">
              <div class="w-14 h-14 rounded-full bg-accent flex items-center justify-center shadow-xl shadow-accent/30">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="text-white ml-1"
                >
                  <path d="M8 5v14l11-7z" />
                </svg>
              </div>
            </div>

            <!-- Duration badge -->
            {video.duration && (
              <div class="absolute bottom-2 right-2 px-2 py-0.5 rounded bg-black/80 text-white text-xs font-mono font-medium">
                {video.duration}
              </div>
            )}

            <!-- YouTube badge -->
            <div class="absolute top-3 left-3 flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-black/60 backdrop-blur-sm">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#ff0000">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              <span class="text-white text-[10px] font-medium">YouTube</span>
            </div>
          </div>

          <!-- Card body -->
          <div class="p-5 flex flex-col flex-1">
            <time class="text-[11px] text-secondary/50 font-medium tabular-nums mb-2">
              {formatDate(video.publishedAt)}
            </time>

            <h2 class="font-display text-base font-bold text-primary group-hover:text-accent transition-colors duration-300 leading-snug mb-2 line-clamp-2">
              {video.title}
            </h2>

            <p class="text-secondary text-xs leading-relaxed line-clamp-2 flex-1">
              {video.description}
            </p>

            <div class="mt-4 flex items-center gap-1.5 text-accent text-[11px] font-semibold uppercase tracking-wider opacity-0 group-hover:opacity-100 translate-x-0 group-hover:translate-x-0.5 transition-all duration-300">
              Watch on YouTube
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </div>
          </div>
        </a>
      ))
    }
  </div>

  <!-- Channel CTA -->
  <div class="mt-24 py-16 rounded-3xl bg-surface border border-white/5 text-center" data-animate data-delay="1">
    <div
      class="w-16 h-16 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center mx-auto mb-6"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="#ef4444">
        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
      </svg>
    </div>
    <h2 class="font-display text-3xl font-bold text-primary mb-3">
      Subscribe for more
    </h2>
    <p class="text-secondary text-base mb-8 max-w-md mx-auto leading-relaxed">
      New videos on software engineering, AI tools, and developer productivity. No fluff.
    </p>
    <a
      href="https://youtube.com/@aravsanj"
      target="_blank"
      rel="noreferrer"
      class="inline-flex items-center gap-3 px-7 py-3.5 rounded-full bg-red-500 hover:bg-red-400 text-white font-bold text-sm transition-all duration-300 shadow-lg shadow-red-500/20"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
      </svg>
      Subscribe on YouTube
    </a>
  </div>
</Layout>
