---
import Layout from "../../layouts/Layout.astro";
import BlogCard from "../../components/BlogCard.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const posts: CollectionEntry<"blog">[] = (await getCollection("blog"))
  .filter((post: CollectionEntry<"blog">) => !post.data.isDraft)
  .sort(
  (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
    new Date(b.data.publishedAt).valueOf() -
    new Date(a.data.publishedAt).valueOf()
);

const postsByYear = posts.reduce(
  (acc, post) => {
    const year = new Date(post.data.publishedAt).getFullYear();
    if (!acc[year]) acc[year] = [];
    acc[year].push(post);
    return acc;
  },
  {} as Record<number, CollectionEntry<"blog">[]>
);

const sortedYears = Object.keys(postsByYear).map(Number).sort((a, b) => b - a);

const metadata = {
  title: "Writing | Aravind Sanjeev",
  description:
    "My journey through the ever-evolving tech landscape. Coding, AI, architecture, and reflections on software engineering.",
};
---

<Layout
  title={metadata.title}
  description={metadata.description}
  mainClass="py-16 max-w-full"
>
  <Breadcrumb crumbs={[]} current="Writing" />

  <!-- Page header -->
  <header class="mb-20">
    <div class="section-label" data-animate>
      <span class="section-label-num">//</span>
      <span class="section-label-text">log_archive</span>
      <div class="section-label-rule"></div>
    </div>
    <h1
      class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold uppercase text-primary leading-[0.95] tracking-tight mb-6"
      data-animate
      data-delay="1"
    >
      Writings
    </h1>
    <p
      class="font-mono text-secondary text-sm sm:text-base max-w-xl leading-relaxed"
      data-animate
      data-delay="2"
    >
      Thoughts on engineering, AI, architecture, and the craft of building software.
      <span class="text-accent">[{posts.length}]</span> articles published.
    </p>
  </header>

  <!-- Posts grouped by year -->
  <div class="space-y-24">
    {
      sortedYears.map((year, index) => (
        <section>
          <!-- Year header -->
          <div
            class="flex items-center gap-5 mb-12"
            data-animate
            data-delay={String((index % 3) + 1)}
          >
            <h2 class="font-mono text-2xl font-bold text-accent/40 tracking-tight flex-shrink-0">
              [{year}]
            </h2>
            <div class="h-px flex-1 bg-gradient-to-r from-accent/25 to-transparent" />
          </div>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-14">
            {postsByYear[year].map((post: CollectionEntry<"blog">, i: number) => (
              <div data-animate data-delay={String((i % 3) + 1)}>
                <BlogCard post={post} />
              </div>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</Layout>
