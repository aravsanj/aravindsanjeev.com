---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import Tag from "../../components/ui/Tag.astro";

type ProjectEntry = CollectionEntry<'projects'>;

export async function getStaticPaths() {
    const projects = await getCollection("projects");
    return projects.map((entry: ProjectEntry) => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

const { entry }: { entry: ProjectEntry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | Aravind Sanjeev`} mainClass="py-24 max-w-full">
    <Breadcrumb crumbs={[{ label: "Projects", href: "/projects" }]} current={entry.data.title} />
    <header class="mb-16 max-w-4xl">
        <div class="section-label" data-animate>
          <span class="section-label-num">//</span>
          <span class="section-label-text">project_file</span>
          <div class="section-label-rule"></div>
        </div>
        <h1 class="font-display text-5xl md:text-6xl font-bold uppercase tracking-tight text-primary mb-8" data-animate data-delay="1">
            {entry.data.title}
        </h1>
            <p class="font-mono text-xl text-secondary leading-relaxed mb-8" data-animate data-delay="2">
                {entry.data.description}
            </p>

            <div class="flex flex-wrap gap-3 mb-10" data-animate data-delay="3">
                {
                    entry.data.tags?.map((tag: string) => (
                        <Tag title={tag} href={`/tag/${tag.toLowerCase()}`} />
                    ))
                }
            </div>

            {
                entry.data.url && (
                    <a
                        href={entry.data.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center px-4 py-2 font-mono text-xs uppercase tracking-[0.12em] bg-accent/5 text-accent border border-accent/40 hover:bg-accent hover:text-background transition-colors acid-glow"
                        data-animate
                        data-delay="4"
                    >
                        [ visit_project ]
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="ml-2"
                        >
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                            <polyline points="15 3 21 3 21 9" />
                            <line x1="10" y1="14" x2="21" y2="3" />
                        </svg>
                    </a>
                )
            }
        </header>

        {
            entry.data.imageUrl && (
                <div class="hud-frame hud-corners mb-16 overflow-hidden border border-border relative" data-animate data-delay="1">
                    <Image
                        src={entry.data.imageUrl}
                        alt={entry.data.title}
                        class="w-full h-auto"
                    />
                    <div class="absolute inset-0 pointer-events-none opacity-25" style="background: repeating-linear-gradient(to bottom, transparent 0 2px, rgba(0,0,0,0.2) 3px 3px);"></div>
                </div>
            )
        }

        <article class="article prose prose-invert prose-lg max-w-none prose-headings:font-display prose-headings:font-bold prose-headings:uppercase prose-headings:tracking-tight" data-animate data-delay="2">
            <Content />
        </article>
</Layout>
