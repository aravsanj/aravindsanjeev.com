---
// src/components/mdx/Kbd.astro
import { Icon } from "astro-icon/components";

const { name } = Astro.props;
---

<kbd
    class="inline-flex items-center px-1.5 py-0.5 text-[10px] font-semibold text-accent bg-surface-2 border border-accent/30 shadow-[0_2px_0_rgba(182,255,26,0.25)] font-mono mx-1 align-middle uppercase tracking-wider"
>
    {name && <Icon name={name} class="w-3 h-3 mr-1" />}
    <slot />
</kbd>
