---
const variants = {
  note: {
    color: "#B6FF1A",
    label: "NOTE",
    icon: "M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  tip: {
    color: "#D4FF5C",
    label: "TIP",
    icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
  },
  important: {
    color: "#FF2D7E",
    label: "IMPORTANT",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
  },
  warning: {
    color: "#FFD166",
    label: "WARNING",
    icon: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z",
  },
  caution: {
    color: "#FF2D7E",
    label: "CAUTION",
    icon: "M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z",
  },
};

interface Props {
  type?: keyof typeof variants;
}

const { type = "note" } = Astro.props;
const { color, label, icon } =
  variants[type as keyof typeof variants] || variants.note;
---

<div
  class="not-prose hud-frame relative my-6 border border-border bg-surface/50 p-4 pl-5"
  style={`border-left: 3px solid ${color}; box-shadow: 0 0 24px ${color}1a;`}
>
  <div class="font-mono text-xs uppercase tracking-[0.18em] mb-2 flex items-center gap-2" style={`color: ${color};`}>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon}></path>
    </svg>
    <span>// {label}</span>
  </div>
  <div class="font-body text-sm md:text-base leading-relaxed text-primary/85 [&_p]:my-2 [&_a]:text-accent">
    <slot />
  </div>
</div>
