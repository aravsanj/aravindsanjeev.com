---
import Tag from "./ui/Tag.astro";
import { experiences, type ExperienceItem } from "../data/experience";
---

<section id="experience" class="py-28 border-t border-border/40">
  <!-- Section header -->
  <div class="flex items-end justify-between mb-16" data-animate>
    <div>
      <div class="section-label">
        <span class="section-label-num">04</span>
        <div class="section-label-rule"></div>
        <span class="section-label-text">Career</span>
      </div>
      <h2 class="font-display text-4xl sm:text-5xl font-bold uppercase tracking-tight text-primary leading-tight">
        Experience
      </h2>
    </div>
    <a
      href="/experience"
      class="hidden sm:flex items-center gap-2 font-mono text-xs uppercase tracking-[0.12em] text-secondary hover:text-accent transition-colors group mb-1"
    >
      [ full_log ]
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="group-hover:translate-x-1 transition-transform duration-300"
      >
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </a>
  </div>

  <!-- Timeline -->
  <div class="relative">
    <!-- Vertical line -->
    <div class="absolute left-0 top-2 bottom-0 w-px bg-gradient-to-b from-accent/25 via-border/50 to-transparent hidden md:block ml-1" aria-hidden="true"></div>

    <div class="space-y-0">
      {
        experiences.slice(0, 2).map((item: ExperienceItem, index: number) => (
          <div
            class="group relative flex gap-8 md:gap-12 pb-12 last:pb-0"
            data-animate
            data-delay={String(index + 1)}
          >
            <!-- Timeline dot (desktop) -->
            <div class="hidden md:flex flex-shrink-0 flex-col items-center" aria-hidden="true">
              <div class="w-2.5 h-2.5 rounded-full bg-background border-2 border-accent/40 group-hover:border-accent group-hover:bg-accent/15 transition-all duration-300 mt-2 relative z-10"></div>
            </div>

            <!-- Content card -->
            <div class="flex-1 relative group/card">
              <div class="hud-frame hud-corners p-6 bg-surface border border-border hover:border-accent/30 transition-all duration-400 card-lift card-sweep">
                <!-- Duration badge -->
                <span class="inline-block font-mono text-[10px] uppercase tracking-[0.15em] text-accent bg-accent/8 border border-accent/25 px-2.5 py-1 mb-4">
                  {item.duration}
                </span>

                <!-- Role & company -->
                <h3 class="font-display text-lg font-bold uppercase tracking-wide text-primary group-hover/card:text-accent transition-colors duration-300 mb-1 relative">
                  {item.companyUrl ? (
                    <a
                      href={item.companyUrl}
                      target="_blank"
                      rel="noreferrer noopener"
                      class="after:absolute after:inset-0"
                    >
                      {item.title}
                      <span class="text-secondary font-medium"> · {item.company}</span>
                    </a>
                  ) : (
                    <span>
                      {item.title}
                      <span class="text-secondary font-medium"> · {item.company}</span>
                    </span>
                  )}
                </h3>

                <!-- Description -->
                <p class="text-secondary font-body text-sm leading-relaxed mt-3 mb-5">
                  {item.description}
                </p>

                <!-- Tech tags -->
                <ul class="flex flex-wrap gap-2 relative z-10">
                  {item.technologies.map((tech: string) => (
                    <li>
                      <Tag title={tech} href={`/tag/${tech.toLowerCase()}`} />
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Fade + See more -->
    <div class="relative -mt-40 pt-40" style="background: linear-gradient(to bottom, transparent 20%, rgba(8,9,10,0.9) 80%);">
      <div class="flex justify-center pb-2" data-animate>
        <a
          href="/experience"
          class="inline-flex items-center gap-2 font-mono text-xs uppercase text-accent tracking-[0.12em] hover:gap-3 transition-all duration-300"
        >
          [ see_more ]
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
