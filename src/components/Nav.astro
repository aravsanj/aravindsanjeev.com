---
const pathname = Astro.url.pathname;

const navLinks = [
  { label: "Projects", href: "/projects" },
  { label: "Experience", href: "/experience" },
  { label: "Writing", href: "/blog" },
  { label: "Videos", href: "/videos" },
];

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50"
  aria-label="Main navigation"
>
  <div class="mx-auto max-w-7xl px-6 md:px-12 lg:px-24">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href="/"
        class="group flex items-center gap-2 hover:opacity-90 transition-opacity duration-300"
        aria-label="Home"
      >
        <span class="font-mono text-accent text-sm acid-text-glow">&#91;</span>
        <span class="glitch font-display text-base font-bold tracking-[0.12em] uppercase text-primary" data-text="A.SANJEEV">A.SANJEEV</span>
        <span class="font-mono text-accent text-sm acid-text-glow">&#93;</span>
      </a>

      <!-- Desktop Links -->
      <div class="hidden md:flex items-center gap-1">
        {
          navLinks.map((link, i) => (
            <a
              href={link.href}
              class={`px-3 py-2 font-mono text-xs uppercase tracking-[0.12em] transition-colors duration-200 ${
                isActive(link.href)
                  ? "text-accent"
                  : "text-secondary hover:text-primary"
              }`}
            >
              <span class="text-accent/40 mr-1">{String(i + 1).padStart(2, "0")}</span>
              {link.label}
            </a>
          ))
        }
        <div class="w-px h-4 bg-border mx-2"></div>
        <a
          href="/contact"
          class="px-3 py-1.5 font-mono text-xs uppercase tracking-[0.14em] text-accent border border-accent/40 bg-accent/5 hover:bg-accent hover:text-background hover:border-accent transition-all duration-200 acid-glow"
        >
          [ HIRE_ME ]
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        aria-label="Toggle menu"
        class="md:hidden flex flex-col gap-1.5 p-2 group"
      >
        <span
          id="hamburger-line-1"
          class="block w-5 h-[1.5px] bg-accent transition-all duration-300 origin-center"
        ></span>
        <span
          id="hamburger-line-2"
          class="block w-5 h-[1.5px] bg-accent transition-all duration-300"
        ></span>
        <span
          id="hamburger-line-3"
          class="block w-5 h-[1.5px] bg-accent transition-all duration-300 origin-center"
        ></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-accent/20 bg-background/95 backdrop-blur-xl"
  >
    <div class="px-6 py-4 flex flex-col gap-1">
      {
        navLinks.map((link, i) => (
          <a
            href={link.href}
            class={`px-4 py-3 font-mono text-sm uppercase tracking-[0.12em] transition-colors ${
              isActive(link.href)
                ? "text-accent"
                : "text-secondary hover:text-primary"
            }`}
          >
            <span class="text-accent/40 mr-2">{String(i + 1).padStart(2, "0")}</span>
            {link.label}
          </a>
        ))
      }
      <a
        href="/contact"
        class="mt-2 px-4 py-3 font-mono text-sm uppercase tracking-[0.14em] text-accent border border-accent/40 bg-accent/5 text-center"
      >
        [ HIRE_ME ]
      </a>
    </div>
  </div>
</nav>

<script>
  function initNav() {
    const nav = document.getElementById("main-nav");
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const line1 = document.getElementById("hamburger-line-1");
    const line2 = document.getElementById("hamburger-line-2");
    const line3 = document.getElementById("hamburger-line-3");

    let menuOpen = false;

    const handleScroll = () => {
      if (window.scrollY > 60) {
        nav?.classList.add("scrolled");
      } else {
        nav?.classList.remove("scrolled");
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });

    const toggleMenu = () => {
      menuOpen = !menuOpen;
      mobileMenu?.classList.toggle("hidden", !menuOpen);

      if (menuOpen) {
        line1?.style.setProperty("transform", "translateY(7px) rotate(45deg)");
        line2?.style.setProperty("opacity", "0");
        line3?.style.setProperty("transform", "translateY(-7px) rotate(-45deg)");
      } else {
        line1?.style.setProperty("transform", "");
        line2?.style.setProperty("opacity", "");
        line3?.style.setProperty("transform", "");
      }
    };

    mobileMenuBtn?.addEventListener("click", toggleMenu);
  }

  document.addEventListener("astro:page-load", initNav);
</script>
