---
import HudPanel from "./ui/HudPanel.astro";
import GlitchText from "./ui/GlitchText.astro";
import BootLine from "./ui/BootLine.astro";
import Social from "./Social.astro";

const startYear = 2020;
const yearsExp = new Date().getFullYear() - startYear;
---

<section class="pt-6 pb-4">
  <!-- Top terminal ribbon -->
  <div data-animate class="flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-[10px] uppercase tracking-[0.18em] text-secondary/70 mb-4">
    <span class="text-accent">// home.dashboard</span>
    <span class="text-secondary/40">—</span>
    <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse-dot"></span>session_active</span>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-6 gap-3 auto-rows-min">

    <!-- IDENTITY -->
    <HudPanel
      label="SYS_01 // OPERATOR"
      class="col-span-2 lg:col-span-4 p-6 sm:p-8 pt-10 flex flex-col justify-center min-h-[340px]"
    >
      <div data-animate data-delay="1" class="font-mono text-xs text-accent/80 space-y-1 mb-6">
        <BootLine prompt="$" text="whoami" class="text-xs" />
        <div class="text-secondary/70 pl-4">// creative frontend engineer · ai fluency</div>
      </div>

      <h1 data-animate data-delay="2" class="font-display font-bold uppercase tracking-tight leading-[0.9] text-[clamp(2.8rem,7vw,5rem)] text-primary">
        Aravind<br />
        <GlitchText as="span" text="Sanjeev" class="text-acid acid-text-glow" />
      </h1>

      <p data-animate data-delay="3" class="font-mono text-sm text-secondary mt-5 max-w-md leading-relaxed">
        I live at the intersection of <span class="text-primary">"how does this work?"</span>
        and <span class="text-primary">"how can we make it better?"</span> — engineering,
        architecture, AI integration, system design &amp; UI/UX.
      </p>

      <div data-animate data-delay="4" class="flex flex-wrap gap-3 mt-7">
        <a href="/projects" class="px-4 py-2 font-mono text-xs uppercase tracking-[0.12em] text-primary border border-border hover:border-accent/50 hover:text-accent transition-all duration-200">
          [ view_work ]
        </a>
        <a href="/contact" class="px-4 py-2 font-mono text-xs uppercase tracking-[0.12em] bg-accent text-background hover:bg-accent-bright transition-all duration-200 acid-glow">
          [ hire_me ]
        </a>
        <a href="/blog" class="px-4 py-2 font-mono text-xs uppercase tracking-[0.12em] text-primary border border-border hover:border-hot/50 hover:text-hot transition-all duration-200">
          [ read_logs ]
        </a>
      </div>
    </HudPanel>

    <!-- VISUAL FEED (main_art) -->
    <HudPanel
      label="SYS_00 // VISUAL_FEED"
      class="col-span-2 lg:col-span-2 lg:row-span-2 overflow-hidden min-h-[260px] lg:min-h-0"
    >
      <div class="relative h-full w-full" id="tv-glitch-container">
        <!-- JS populates band layers here -->
        <!-- scanline + tint overlays -->
        <div class="absolute inset-0 pointer-events-none mix-blend-overlay" style="background: linear-gradient(180deg, rgba(182,255,26,0.06), transparent 40%, rgba(255,45,126,0.07)); z-index:10;"></div>
        <div class="absolute inset-0 pointer-events-none opacity-50" style="background: repeating-linear-gradient(to bottom, transparent 0 2px, rgba(0,0,0,0.18) 3px 3px); z-index:11;"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-background/80 via-transparent to-background/30 pointer-events-none" style="z-index:12;"></div>
        <!-- caption -->
        <div class="absolute bottom-3 left-3 right-3 flex items-center justify-between font-mono text-[10px] uppercase tracking-[0.15em]">
          <span class="text-accent acid-text-glow">&gt; operator_AS</span>
          <span class="flex items-center gap-1.5 text-hot"><span class="w-1.5 h-1.5 rounded-full bg-hot animate-pulse-dot"></span>rec</span>
        </div>
      </div>
    </HudPanel>

    <!-- METRICS -->
    <HudPanel
      label="SYS_02 // METRICS"
      variant="hot"
      class="col-span-1 lg:col-span-2 p-5 pt-9 flex flex-col justify-center"
      hover
    >
      <div class="grid grid-cols-2 gap-4">
        <div>
          <div class="font-display text-3xl font-bold text-accent acid-text-glow">10<span class="text-hot">+</span></div>
          <div class="font-mono text-[9px] uppercase tracking-[0.15em] text-secondary mt-1">projects</div>
        </div>
        <div>
          <div class="font-display text-3xl font-bold text-accent acid-text-glow">{yearsExp}<span class="text-hot">Y</span></div>
          <div class="font-mono text-[9px] uppercase tracking-[0.15em] text-secondary mt-1">experience</div>
        </div>
        <div>
          <div class="font-display text-3xl font-bold text-accent acid-text-glow">3</div>
          <div class="font-mono text-[9px] uppercase tracking-[0.15em] text-secondary mt-1">domains</div>
        </div>
        <div>
          <div class="font-display text-3xl font-bold text-accent acid-text-glow">&#8734;</div>
          <div class="font-mono text-[9px] uppercase tracking-[0.15em] text-secondary mt-1">coffee</div>
        </div>
      </div>
    </HudPanel>

    <!-- UPLINK / STATUS -->
    <HudPanel
      label="SYS_03 // UPLINK"
      class="col-span-1 lg:col-span-2 p-5 pt-9 flex flex-col justify-center gap-3"
      hover
    >
      <div class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.14em] text-accent">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse-dot acid-glow"></span>
        available_for_work
      </div>
      <a href="mailto:hi@aravindsanjeev.com" class="font-mono text-xs text-secondary hover:text-accent transition-colors break-all">
        &gt; hi@aravindsanjeev.com
      </a>
      <div class="text-hot pt-1">
        <Social
          email="hi@aravindsanjeev.com"
          linkedIn="aravsanj"
          instagram="aravsanj"
          twitter="aravsanj"
        />
      </div>
    </HudPanel>

  </div>
</section>

<style>
  #tv-glitch-container .tv-band {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: top center;
    background-repeat: no-repeat;
  }
</style>

<script>
function initTvGlitch() {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  const IMG_A = '/assets/main_art.png';
  const IMG_B = '/assets/main_art_2.png';
  const BAND_COUNT = 12;
  const GLITCH_INTERVAL = 2000;
  const GLITCH_DURATION = 500;
  const FRAME_MS = 35;

  const container = document.getElementById('tv-glitch-container');
  if (!container) return;

  // Clear any previously injected bands (e.g. on back-navigation)
  container.querySelectorAll('.tv-band').forEach(el => el.remove());

  const bands = Array.from({ length: BAND_COUNT }, () => {
    const el = document.createElement('div');
    el.className = 'tv-band';
    container.prepend(el);
    return el;
  });

  function rand(min, max) { return min + Math.random() * (max - min); }

  function showNormal() {
    bands.forEach((b, i) => {
      if (i === 0) {
        b.style.cssText = `position:absolute;inset:0;background-size:cover;background-position:top center;background-image:url(${IMG_A});opacity:0.95;`;
      } else {
        b.style.opacity = '0';
      }
    });
  }

  function glitchFrame(useAlt) {
    const slices = [0];
    let y = 0;
    while (y < 98) {
      y += rand(2, 22);
      slices.push(Math.min(y, 100));
    }
    if (slices[slices.length - 1] < 100) slices.push(100);

    const usedBands = Math.min(slices.length - 1, BAND_COUNT);

    bands.forEach((b, i) => {
      if (i >= usedBands) { b.style.opacity = '0'; return; }

      const y0 = slices[i];
      const y1 = slices[i + 1];
      const dx = rand(-14, 14);
      const showB = useAlt ? Math.random() > 0.35 : Math.random() > 0.75;
      const img = showB ? IMG_B : IMG_A;

      let filter = 'none';
      const r = Math.random();
      if (r > 0.82) filter = `hue-rotate(${Math.floor(rand(60, 300))}deg) saturate(${rand(1.5, 3)})`;
      else if (r > 0.7) filter = `brightness(${rand(1.4, 2)}) saturate(0)`;

      b.style.cssText = `
        position:absolute;inset:0;
        background-size:cover;background-position:top center;background-repeat:no-repeat;
        background-image:url(${img});
        clip-path:polygon(0 ${y0}%,100% ${y0}%,100% ${y1}%,0 ${y1}%);
        transform:translateX(${dx}px);
        filter:${filter};
        opacity:0.95;
      `;
    });
  }

  function runGlitch() {
    const start = performance.now();

    function tick() {
      const elapsed = performance.now() - start;
      if (elapsed >= GLITCH_DURATION) { showNormal(); return; }

      const progress = elapsed / GLITCH_DURATION;
      const useAlt = progress > 0.25 && progress < 0.75;

      if (Math.random() > 0.88) {
        container.style.filter = 'brightness(2.5)';
        setTimeout(() => { container.style.filter = ''; }, 25);
      }

      glitchFrame(useAlt);
      setTimeout(tick, FRAME_MS);
    }

    tick();
  }

  showNormal();
  setInterval(runGlitch, GLITCH_INTERVAL);
}

document.addEventListener('astro:page-load', initTvGlitch);
</script>
