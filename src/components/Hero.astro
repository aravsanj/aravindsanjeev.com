---
import { Image } from "astro:assets";
import profileImage from "../assets/profile_transparent.webp";
---

<section class="relative min-h-[calc(100vh-64px)] flex flex-col justify-center overflow-hidden py-20 lg:py-0">

  <!-- Background: amber spotlight top-right, subtle grid -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div
      class="absolute -top-40 right-0 w-[700px] h-[700px] rounded-full opacity-[0.07]"
      style="background: radial-gradient(circle, #C9963A 0%, transparent 65%);"
    ></div>
    <div
      class="absolute bottom-0 -left-20 w-[450px] h-[450px] rounded-full opacity-[0.04]"
      style="background: radial-gradient(circle, #4A6FA5 0%, transparent 65%);"
    ></div>
    <!-- Fine dot grid -->
    <div
      class="absolute inset-0 opacity-[0.025]"
      style="background-image: radial-gradient(circle, rgba(237,232,223,0.8) 1px, transparent 1px); background-size: 48px 48px;"
    ></div>
    <!-- Thin horizontal rule at bottom of hero -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
  </div>

  <div class="relative grid grid-cols-1 lg:grid-cols-5 gap-16 lg:gap-12 items-center max-w-6xl mx-auto w-full">

    <!-- Text content -->
    <div class="lg:col-span-3 order-2 lg:order-1 text-center lg:text-left">

      <!-- Status badge -->
      <div data-animate data-delay="1" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-accent/25 text-accent text-[11px] font-sans font-semibold tracking-[0.15em] uppercase bg-accent/5">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse-dot"></span>
        Available for work
      </div>

      <!-- Name -->
      <h1 data-animate data-delay="2" class="font-display text-[clamp(4rem,10vw,6.5rem)] font-black text-primary tracking-tight leading-[0.92] mt-6 pb-1">
        Aravind<br />
        <span class="gradient-text">Sanjeev</span>
      </h1>

      <!-- Role -->
      <p data-animate data-delay="3" class="text-base sm:text-lg text-secondary font-sans font-medium mt-5  tracking-wide">
        Creative Frontend Engineer
      </p>

      <!-- Thin separator -->
      <div data-animate data-delay="3" class="flex justify-center lg:justify-start mt-5">
        <div class="w-12 h-px bg-accent/40"></div>
      </div>

      <!-- Skill badges -->
      <div data-animate data-delay="4" class="flex flex-wrap justify-center lg:justify-start gap-2 mt-5">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-surface-2 border border-border text-xs font-sans font-semibold text-secondary tracking-wide">
          <span class="w-1.5 h-1.5 rounded-full bg-accent/60"></span>Web
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-surface-2 border border-border text-xs font-sans font-semibold text-secondary tracking-wide">
          <span class="w-1.5 h-1.5 rounded-full bg-accent/60"></span>Mobile
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-surface-2 border border-border text-xs font-sans font-semibold text-secondary tracking-wide">
          <span class="w-1.5 h-1.5 rounded-full bg-accent/60"></span>AI
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-surface-2 border border-border text-xs font-sans font-semibold text-secondary tracking-wide">
          <span class="w-1.5 h-1.5 rounded-full bg-accent/60"></span>10+ projects delivered
        </span>
      </div>

      <!-- Bio -->
      <p data-animate data-delay="5" class="text-base text-secondary/75 leading-relaxed mt-5 max-w-lg mx-auto lg:mx-0 font-body">
        I live at the intersection of
        <em class="text-primary/90 not-italic font-semibold">"how does this work?"</em>
        and
        <em class="text-primary/90 not-italic font-semibold">"how can we make it better?"</em>
        — spanning Engineering, Architecture, AI Integration, System Design, and UI/UX.
      </p>

      <!-- CTA buttons -->
      <div data-animate data-delay="6" class="flex flex-wrap justify-center lg:justify-start gap-3 mt-8">
        <a
          href="/projects"
          class="px-5 py-2.5 rounded-lg bg-surface-2 text-primary border border-border hover:border-accent/35 hover:bg-accent/5 transition-all duration-300 font-sans font-semibold text-sm tracking-wide"
        >
          View Work
        </a>
        <a
          href="/contact"
          class="px-5 py-2.5 rounded-lg bg-accent text-background hover:bg-accent-bright transition-all duration-300 font-sans font-bold text-sm tracking-wide shadow-lg shadow-accent/15"
        >
          Hire Me
        </a>
        <a
          href="/blog"
          class="px-5 py-2.5 rounded-lg bg-surface-2 text-primary border border-border hover:border-accent/35 hover:bg-accent/5 transition-all duration-300 font-sans font-semibold text-sm tracking-wide"
        >
          Read My Writing
        </a>
      </div>

      <!-- Email -->
      <div data-animate data-delay="7" class="mt-6 flex justify-center lg:justify-start">
        <a
          href="mailto:hi@aravindsanjeev.com"
          class="group flex items-center gap-2.5 text-xs text-secondary hover:text-accent transition-colors duration-300 font-sans tracking-wider"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:scale-110">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          hi@aravindsanjeev.com
        </a>
      </div>
    </div>

    <!-- Profile image with crop-mark frame -->
    <div data-animate data-delay="2" class="lg:col-span-2 order-1 lg:order-2 flex justify-center">
      <div class="relative p-5">
        <!-- Corner crop marks: all 4 as child elements (immune to overflow clipping) -->
        <span class="absolute top-0 left-0 w-5 h-5 pointer-events-none z-10" style="border-top: 1.5px solid rgba(201,150,58,0.7); border-left: 1.5px solid rgba(201,150,58,0.7);"></span>
        <span class="absolute top-0 right-0 w-5 h-5 pointer-events-none z-10" style="border-top: 1.5px solid rgba(201,150,58,0.7); border-right: 1.5px solid rgba(201,150,58,0.7);"></span>
        <span class="absolute bottom-0 left-0 w-5 h-5 pointer-events-none z-10" style="border-bottom: 1.5px solid rgba(201,150,58,0.7); border-left: 1.5px solid rgba(201,150,58,0.7);"></span>
        <span class="absolute bottom-0 right-0 w-5 h-5 pointer-events-none z-10" style="border-bottom: 1.5px solid rgba(201,150,58,0.7); border-right: 1.5px solid rgba(201,150,58,0.7);"></span>
        <!-- Amber glow beneath image -->
        <div
          class="absolute inset-x-6 bottom-0 h-3/4 blur-[60px] opacity-20 rounded-full"
          style="background: #C9963A;"
          aria-hidden="true"
        ></div>
        <Image
          fetchpriority="high"
          loading="eager"
          src={profileImage}
          alt="Aravind Sanjeev"
          class="relative w-60 sm:w-72 lg:w-full lg:max-w-[340px] aspect-square object-contain animate-float"
          style="filter: drop-shadow(0 0 32px rgba(201,150,58,0.18));"
        />
        <!-- Signature label -->
        <div class="absolute bottom-2 right-4 pointer-events-none" style="font-family: 'Dancing Script', cursive; font-size: 1.15rem; color: rgba(201,150,58,0.6); line-height: 1; transform: rotate(-2deg);">
          Aravind Sanjeev
        </div>
      </div>
    </div>

  </div>

</section>
