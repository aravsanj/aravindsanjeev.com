---
import Tag from "./ui/Tag.astro";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

type BlogEntry = CollectionEntry<'blog'>;

const { posts } = Astro.props;
const sortedBlogs = posts.sort(
  (a: BlogEntry, b: BlogEntry) =>
    new Date(b.data.publishedAt).getTime() -
    new Date(a.data.publishedAt).getTime(),
);
---

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
  {
    sortedBlogs.map((post: BlogEntry, i: number) => {
      const tags = post.data.tags || [];
      return (
        <div class="hud-frame hud-corners card-lift card-sweep group relative flex flex-col gap-6 p-4 bg-surface/60 border border-border hover:border-accent/30 transition-all duration-300" data-animate data-delay={String((i % 3) + 1)}>
          <div class="aspect-video w-full bg-surface border border-border/60 overflow-hidden relative">
            {post.data.image ? (
              <Image
                src={post.data.image}
                alt={post.data.title}
                class="w-full h-full object-cover saturate-[0.9] group-hover:saturate-100 group-hover:scale-105 transition-all duration-500"
              />
            ) : (
              <div class="w-full h-full flex flex-col justify-between p-4 overflow-hidden relative pointer-events-none">
                <div class="absolute inset-0 opacity-50" style="background-image: radial-gradient(circle, #243018 1px, transparent 1px); background-size: 20px 20px;"></div>
                <span class="font-mono text-[9px] text-secondary/40 uppercase tracking-widest relative z-10">&gt; aravindsanjeev.com</span>
                <p class="font-display text-sm font-bold uppercase tracking-wide text-accent leading-tight relative z-10 line-clamp-3 group-hover:text-accent-bright transition-colors duration-300">
                  {post.data.coverText || post.data.title}
                </p>
                <span class="font-mono text-[9px] text-border uppercase tracking-widest relative z-10">sys://blog/{post.slug}</span>
              </div>
            )}
            <div class="absolute inset-0 pointer-events-none opacity-30" style="background: repeating-linear-gradient(to bottom, transparent 0 2px, rgba(0,0,0,0.2) 3px 3px);"></div>
          </div>
          <div class="flex flex-col flex-1">
            <h3 class="font-display text-xl font-bold uppercase tracking-wide text-primary mb-3 group-hover:text-accent transition-colors leading-tight">
              <a href={`/${post.slug}`} class="after:absolute after:inset-0">
                {post.data.title}
              </a>
            </h3>
            <p class="text-secondary text-base leading-relaxed mb-6 line-clamp-3">
              {post.data.summary}
            </p>
            <ul class="mt-auto flex flex-wrap gap-2 relative z-10">
              {tags.map((tag: string) => (
                <li>
                  <Tag title={tag} href={`/tag/${tag.toLowerCase()}`} />
                </li>
              ))}
            </ul>
          </div>
        </div>
      );
    })
  }
</div>
