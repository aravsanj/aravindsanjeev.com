---
---

<section class="mt-24 mb-2">
  <div class="relative overflow-hidden rounded-2xl border border-accent/20 bg-gradient-to-r from-accent/8 via-accent/4 to-transparent px-8 py-12 md:px-14 md:py-14">

    <!-- Background blobs -->
    <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-accent/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-10 left-1/3 h-40 w-40 rounded-full bg-accent/6 blur-2xl"></div>

    <div class="relative flex flex-col gap-8 md:flex-row md:items-center md:justify-between">

      <!-- Text -->
      <div class="max-w-lg">
        <p data-animate class="font-sans text-[10px] font-bold uppercase tracking-[0.2em] text-accent/60 mb-3">Work together</p>
        <h2 data-animate data-delay="1" class="font-display text-2xl md:text-3xl font-semibold text-primary leading-snug">
          Have a project in mind?
        </h2>
        <p data-animate data-delay="2" class="mt-3 font-body text-secondary text-sm md:text-base leading-relaxed">
          Let's talk about how I can help — whether it's a full build, a quick strategy session, or just a second opinion.
        </p>
      </div>

      <!-- Actions: stacked vertically, cleanly aligned -->
      <div class="flex flex-col gap-3 shrink-0 min-w-[200px]">
        <p data-animate data-delay="3" class="font-sans text-xs text-secondary/80">* Free, no obligations</p>
        <a data-animate data-delay="4"
          href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ3XMK9NOox_TPLSyObRx_nRYu49-PV1f2bGqMqrCOp-vYJdiNP2MfcdKTSxxtfrR3IjO6PeHW9z"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-between gap-3 rounded-lg bg-accent px-5 py-3 font-sans text-sm font-semibold text-background transition-all duration-200 hover:bg-accent/85 hover:shadow-[0_4px_20px_rgba(201,150,58,0.35)] active:scale-[0.97]"
        >
          <span>Book a strategy call</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          data-animate data-delay="5"
          href="/contact"
          class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-border/60 px-5 py-3 font-sans text-sm font-medium text-secondary transition-all duration-200 hover:border-accent/40 hover:text-primary active:scale-[0.97]"
        >
          Or send a message
        </a>
      </div>

    </div>
  </div>
</section>
