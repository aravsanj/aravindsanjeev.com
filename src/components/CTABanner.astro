---
import HudPanel from "./ui/HudPanel.astro";
---

<section class="mt-24 mb-2">
  <HudPanel label="TRANSMISSION // OPEN" glow class="overflow-hidden px-8 py-12 md:px-14 md:py-14">
    <!-- glow blobs -->
    <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-accent/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-10 left-1/3 h-40 w-40 rounded-full bg-hot/8 blur-2xl"></div>

    <div class="relative flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
      <!-- Text -->
      <div class="max-w-lg">
        <p data-animate class="font-mono text-[10px] uppercase tracking-[0.22em] text-accent mb-3">&gt; work_together</p>
        <h2 data-animate data-delay="1" class="font-display text-2xl md:text-4xl font-bold text-primary leading-tight uppercase tracking-tight">
          Have a project<br /><span class="text-acid acid-text-glow">in mind?</span>
        </h2>
        <p data-animate data-delay="2" class="mt-4 font-body text-secondary text-sm md:text-base leading-relaxed">
          Let's talk about how I can help &mdash; whether it's a full build, a quick strategy session, or just a second opinion.
        </p>
      </div>

      <!-- Actions -->
      <div class="flex flex-col gap-3 shrink-0 min-w-[220px]">
        <p data-animate data-delay="3" class="font-mono text-[11px] uppercase tracking-wide text-secondary/70">// free, no obligations</p>
        <a data-animate data-delay="4"
          href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ3XMK9NOox_TPLSyObRx_nRYu49-PV1f2bGqMqrCOp-vYJdiNP2MfcdKTSxxtfrR3IjO6PeHW9z"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center justify-between gap-3 bg-accent px-5 py-3 font-mono text-sm uppercase tracking-[0.1em] text-background transition-all duration-200 hover:bg-accent-bright hover:shadow-[0_0_24px_rgba(182,255,26,0.5)] active:scale-[0.98]"
        >
          <span>Book a call</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a data-animate data-delay="5"
          href="/contact"
          class="inline-flex items-center justify-center gap-1.5 border border-border px-5 py-3 font-mono text-sm uppercase tracking-[0.1em] text-secondary transition-all duration-200 hover:border-hot/50 hover:text-hot active:scale-[0.98]"
        >
          Or send a message
        </a>
      </div>
    </div>
  </HudPanel>
</section>
