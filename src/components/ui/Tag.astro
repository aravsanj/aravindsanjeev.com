---
const { title, href } = Astro.props;
const TagElement = href ? "a" : "span";
---

<TagElement
  href={href}
  class="inline-flex items-center gap-1 bg-accent/8 px-2 py-0.5 font-mono text-[10px] uppercase tracking-[0.12em] text-accent border border-accent/25 hover:bg-accent/18 hover:border-accent/50 transition-colors duration-200 no-underline"
>
  <span class="text-accent/50">#</span>{title}
</TagElement>
