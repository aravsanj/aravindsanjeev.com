---
import Tag from "./ui/Tag.astro";
import { Picture } from "astro:assets";

interface Props {
  title: string;
  description: string;
  url: string;
  imageUrl: ImageMetadata;
  tags: string[];
}

const { title, description, url, imageUrl, tags } = Astro.props;
---

<article
  class="hud-frame hud-corners card-lift card-sweep group relative flex flex-col w-full bg-surface border border-border overflow-hidden"
>
  <!-- Image -->
  <div class="aspect-[16/10] w-full overflow-hidden relative">
    <Picture
      src={imageUrl}
      alt={title}
      widths={[400, 800]}
      sizes="(max-width: 767px) calc(100vw - 48px), (max-width: 1023px) calc((100vw - 96px) / 2), 380px"
      formats={["avif", "webp"]}
      decoding="async"
      fetchpriority="high"
      class="w-full h-full object-cover saturate-[0.9] group-hover:scale-[1.04] group-hover:saturate-100 transition-all duration-700 ease-out"
    />
    <!-- scanline + gradient overlays -->
    <div class="absolute inset-0 pointer-events-none opacity-40" style="background: repeating-linear-gradient(to bottom, transparent 0 2px, rgba(0,0,0,0.2) 3px 3px);"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/20 to-transparent pointer-events-none"></div>
    <!-- acid top scan line on hover -->
    <div class="absolute top-0 left-0 right-0 h-px bg-accent scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left acid-glow"></div>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5">
    <h2 class="font-display text-lg font-bold uppercase tracking-wide text-primary mb-2 group-hover:text-accent transition-colors duration-300 leading-snug">
      <a href={url} class="after:absolute after:inset-0 after:content-['']">
        {title}
      </a>
    </h2>
    <p class="text-secondary font-body text-sm leading-relaxed mb-5 line-clamp-2 flex-1">
      {description}
    </p>
    <ul class="flex flex-wrap gap-2 relative z-10">
      {
        tags.map((tag) => (
          <li>
            <Tag title={tag} href={`/tag/${tag.toLowerCase()}`} />
          </li>
        ))
      }
    </ul>
  </div>
</article>
