---
import Tag from "./ui/Tag.astro";
import { Picture } from "astro:assets";

interface Props {
  title: string;
  description: string;
  url: string;
  imageUrl: ImageMetadata;
  tags: string[];
}

const { title, description, url, imageUrl, tags } = Astro.props;
---

<article
  class="group relative flex flex-col w-full rounded-xl bg-surface border border-border/60 hover:border-accent/25 transition-all duration-400 overflow-hidden card-lift"
>
  <!-- Image -->
  <div class="aspect-[16/10] w-full overflow-hidden relative">
    <Picture
      src={imageUrl}
      alt={title}
      widths={[400, 800]}
      sizes="(max-width: 767px) calc(100vw - 48px), (max-width: 1023px) calc((100vw - 96px) / 2), 380px"
      formats={["avif", "webp"]}
      decoding="async"
      fetchpriority="high"
      class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-700 ease-out"
    />
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-surface/90 via-transparent to-transparent"></div>
  </div>

  <!-- Amber top accent line on hover -->
  <div class="absolute top-0 left-0 right-0 h-px bg-accent scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5">
    <h2 class="font-display text-xl font-bold text-primary mb-2 group-hover:text-accent transition-colors duration-300 leading-snug">
      <a href={url} class="after:absolute after:inset-0">
        {title}
      </a>
    </h2>
    <p class="text-secondary font-body text-sm leading-relaxed mb-5 line-clamp-2 flex-1">
      {description}
    </p>
    <ul class="flex flex-wrap gap-2 relative z-10">
      {
        tags.map((tag) => (
          <li>
            <Tag title={tag} href={`/tag/${tag.toLowerCase()}`} />
          </li>
        ))
      }
    </ul>
  </div>
</article>
