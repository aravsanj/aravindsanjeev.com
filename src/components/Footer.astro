---
const year = new Date().getFullYear();
---

<footer class="relative border-t border-accent/20 mt-20 pt-10 pb-12">
  <!-- terminal status strip -->
  <div data-animate class="flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-[10px] uppercase tracking-[0.15em] text-secondary/70 mb-10">
    <span class="text-accent">// SYSTEM</span>
    <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse-dot"></span>ONLINE</span>
    <span class="text-secondary/40">/</span>
    <span>UPTIME: {year - 2015}Y</span>
    <span class="text-secondary/40">/</span>
    <span>LOC: 9.9312&deg;N 76.2673&deg;E</span>
  </div>

  <div class="flex flex-col md:flex-row items-start md:items-start justify-between gap-10">
    <!-- Brand -->
    <div class="max-w-xs">
      <a data-animate href="/" class="font-display text-xl font-bold text-primary hover:text-accent transition-colors duration-300 tracking-[0.1em] uppercase">
        Aravind&nbsp;Sanjeev
      </a>
      <p data-animate data-delay="1" class="text-secondary text-sm mt-3 leading-relaxed font-body">
        Creative Frontend Engineer &amp; AI Stack Engineer. Building things at the intersection of code and creativity.
      </p>
      <div data-animate data-delay="2" class="w-10 h-px bg-accent/50 mt-4"></div>
    </div>

    <!-- Nav columns -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-8">
      <div>
        <p data-animate class="font-mono text-[10px] uppercase tracking-[0.2em] text-accent/60 mb-4">&gt; pages</p>
        <ul class="space-y-2.5">
          <li data-animate data-delay="1"><a href="/" class="text-secondary hover:text-accent transition-colors font-mono text-xs tracking-wide">Home</a></li>
          <li data-animate data-delay="2"><a href="/projects" class="text-secondary hover:text-accent transition-colors font-mono text-xs tracking-wide">Work</a></li>
          <li data-animate data-delay="3"><a href="/blog" class="text-secondary hover:text-accent transition-colors font-mono text-xs tracking-wide">Writing</a></li>
          <li data-animate data-delay="4"><a href="/videos" class="text-secondary hover:text-accent transition-colors font-mono text-xs tracking-wide">Videos</a></li>
        </ul>
      </div>
      <div>
        <p data-animate class="font-mono text-[10px] uppercase tracking-[0.2em] text-accent/60 mb-4">&gt; connect</p>
        <ul class="space-y-2.5">
          <li data-animate data-delay="1"><a href="mailto:hi@aravindsanjeev.com" class="text-secondary hover:text-hot transition-colors font-mono text-xs tracking-wide">Email</a></li>
          <li data-animate data-delay="2"><a href="https://twitter.com/aravsanj" target="_blank" rel="noreferrer" class="text-secondary hover:text-hot transition-colors font-mono text-xs tracking-wide">Twitter / X</a></li>
          <li data-animate data-delay="3"><a href="https://linkedin.com/in/aravsanj" target="_blank" rel="noreferrer" class="text-secondary hover:text-hot transition-colors font-mono text-xs tracking-wide">LinkedIn</a></li>
          <li data-animate data-delay="4"><a href="https://github.com/aravsanj" target="_blank" rel="noreferrer" class="text-secondary hover:text-hot transition-colors font-mono text-xs tracking-wide">GitHub</a></li>
        </ul>
      </div>
      <div>
        <p data-animate class="font-mono text-[10px] uppercase tracking-[0.2em] text-accent/60 mb-4">&gt; explore</p>
        <ul class="space-y-2.5">
          <li data-animate data-delay="1"><a href="/tag" class="text-secondary hover:text-accent transition-colors font-mono text-xs tracking-wide">All Topics</a></li>
          <li data-animate data-delay="2"><a href="/contact" class="text-secondary hover:text-accent transition-colors font-mono text-xs tracking-wide">Hire Me</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="mt-12 pt-6 border-t border-border/40 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p data-animate class="font-mono text-secondary/40 text-[11px] tracking-wide">
      &copy; {year} ARAVIND_SANJEEV &mdash; ALL RIGHTS RESERVED
    </p>
    <p data-animate data-delay="1" class="font-mono text-secondary/30 text-[11px] tracking-wide">
      BUILT_WITH: ASTRO + TAILWIND
    </p>
  </div>
</footer>
